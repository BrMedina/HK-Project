{
  "expo": {
    "name": "GalaFund",
    "slug": "gala-fund",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/GalaFundLogoPreview.png",
    "scheme": "galafund",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/GalaFundLogoPreview.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/GalaFundLogoPreview.png",
        "backgroundImage": "./assets/GalaFundLogoPreview.png",
        "monochromeImage": "./assets/GalaFundLogoPreview.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.galafund",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-share-intent",
        {
          "androidIntentFilters": [
            "image/*"
          ]
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "QuickAdd",
              "label": "Gala Fund — Quick Add",
              "minWidth": "220dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "description": "See today's spend and log an expense in one tap.",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Gala Fund to access your camera to scan QR codes and receipts."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f77d082e-2d7d-4f51-9de3-7a9f0a426c90"
      }
    }
  }
}